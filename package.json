{
  "name": "@parel-cloud/node",
  "version": "0.1.1",
  "description": "Parel SDK for JavaScript/TypeScript. 100+ AI models, GPU rental (BYOM), compare, and credits via a single OpenAI-compatible API. Official client for parel.cloud.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "parel",
    "ai",
    "llm",
    "gpu",
    "openai",
    "openai-compatible",
    "sdk",
    "byom",
    "huggingface",
    "inference",
    "compare",
    "image-generation",
    "video-generation",
    "tts",
    "stt",
    "embeddings"
  ],
  "author": "Parel Cloud <hello@parel.cloud>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parel-cloud/parel-node.git"
  },
  "bugs": {
    "url": "https://github.com/parel-cloud/parel-node/issues"
  },
  "homepage": "https://parel.cloud",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "openai": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "openai": "^4.70.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "msw": "^2.6.0"
  }
}
